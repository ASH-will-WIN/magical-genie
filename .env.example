# OpenAI
OPENAI_API_KEY=sk-...

# Apollo.io
APOLLO_API_KEY=...

# Monthly Apollo credit allowance (used by Phase 7 cost dashboard)
APOLLO_CREDITS_LIMIT=4000

# SQLite path
DATABASE_PATH=campaigns.db

# Base URL used when building UTM tracking links (your landing/redirect domain)
TRACKING_BASE_URL=https://track.example.com/r

# Optional lead-fetch testing caps for the ICP/Venn pipeline. Leave unset for
# unlimited (no effect). Useful for bounding Apollo credit spend while testing.
# MAX_LEAD_FETCH_COMPANIES=10
# MAX_LEADS_PER_CAMPAIGN=20
